<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2011/08/nuspec.xsd">
  <metadata>
    <id>VST.NET2-Plugin</id>
    <title>VST.NET 2.0 Library for Plugins</title>
    <version>2.1.10</version>
    <authors>Marc Jacobi</authors>
    <owners>Jacobi Software</owners>
    <license type="expression">LGPL-2.1-only</license>
    <projectUrl>https://github.com/obiwanjacobi/vst.net</projectUrl>
    <repository type="git" url="https://github.com/obiwanjacobi/vst.net" />
    <!--<icon></icon>-->
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>VST.NET dotnet 10 primary assemblies for building a VST2 plugin in Windows.</description>
    <releaseNotes>
    </releaseNotes>
    <copyright>Copyright © 2008-2026 Jacobi Software</copyright>
    <tags>vst vstnet</tags>
    <dependencies>
      <group targetFramework="net10.0-windows">
        <dependency id="Microsoft.Extensions.DependencyInjection" version="10.0.0" />
        <dependency id="Microsoft.Extensions.Configuration.Json" version="10.0.0" />
        <dependency id="Microsoft.Extensions.Logging" version="10.0.0" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="VST.NET2-Plugin.targets" target="build"></file>
    <file src="VST.NET2-Plugin.props" target="build"></file>
    <file src="..\VstNetDeploy.targets" target="build"></file>

    <file src="..\..\x86\$config$\Plugin\ijwhost.dll" target="runtimes\win-x86\native"></file>
    <file src="..\..\x64\$config$\Plugin\ijwhost.dll" target="runtimes\win-x64\native"></file>
    
    <!-- dotnet 10 -->
    <file src="..\..\x86\$config$\Plugin\Jacobi.Vst.Plugin.Interop.dll" target="lib\net10.0-windows\x86"></file>
    <file src="..\..\x86\$config$\Plugin\Jacobi.Vst.Plugin.Interop.xml" target="lib\net10.0-windows\x86"></file>
    <file src="..\..\Jacobi.Vst.Core\bin\x86\$config$\net10.0-windows\Jacobi.Vst.Core.dll" target="lib\net10.0-windows\x86"></file>
    <file src="..\..\Jacobi.Vst.Core\bin\x86\$config$\net10.0-windows\Jacobi.Vst.Core.xml" target="lib\net10.0-windows\x86"></file>
    <file src="..\..\Jacobi.Vst.Plugin.Framework\bin\x86\$config$\net10.0-windows\Jacobi.Vst.Plugin.Framework.dll" target="lib\net10.0-windows\x86"></file>
    <file src="..\..\Jacobi.Vst.Plugin.Framework\bin\x86\$config$\net10.0-windows\Jacobi.Vst.Plugin.Framework.xml" target="lib\net10.0-windows\x86"></file>

    <file src="..\..\x64\$config$\Plugin\Jacobi.Vst.PLugin.Interop.dll" target="lib\net10.0-windows\x64"></file>
    <file src="..\..\x64\$config$\Plugin\Jacobi.Vst.PLugin.Interop.xml" target="lib\net10.0-windows\x64"></file>
    <file src="..\..\Jacobi.Vst.Core\bin\x64\$config$\net10.0-windows\Jacobi.Vst.Core.dll" target="lib\net10.0-windows\x64"></file>
    <file src="..\..\Jacobi.Vst.Core\bin\x64\$config$\net10.0-windows\Jacobi.Vst.Core.xml" target="lib\net10.0-windows\x64"></file>
    <file src="..\..\Jacobi.Vst.Plugin.Framework\bin\x64\$config$\net10.0-windows\Jacobi.Vst.Plugin.Framework.dll" target="lib\net10.0-windows\x64"></file>
    <file src="..\..\Jacobi.Vst.Plugin.Framework\bin\x64\$config$\net10.0-windows\Jacobi.Vst.Plugin.Framework.xml" target="lib\net10.0-windows\x64"></file>

    <file src="..\..\Jacobi.Vst.CLI\bin\$config$\net10.0-windows\vstnet.exe" target="tools\net10.0-windows"></file>
    <file src="..\..\Jacobi.Vst.CLI\bin\$config$\net10.0-windows\vstnet.dll" target="tools\net10.0-windows"></file>
    <file src="..\..\Jacobi.Vst.CLI\bin\$config$\net10.0-windows\vstnet.runtimeconfig.json" target="tools\net10.0-windows"></file>
  </files>
</package>